# Crest Study Consult Blog Environment Variables
# Copy to .env and fill in values

# ============================================
# Database (Required)
# ============================================
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/Crest Study Consult_blog?schema=public"

# Direct connection URL (bypasses pooler for migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/Crest Study Consult_blog?schema=public"

# ============================================
# Application
# ============================================
BASE_URL="https://blog.creststudyconsult.com"
NODE_ENV="development"

# ============================================
# Session Secret (Required for auth)
# Generate with: openssl rand -hex 32
# ============================================
SESSION_SECRET="your-session-secret-here-min-32-chars"

# ============================================
# Analytics (Phase 4)
# ============================================
# Plausible Analytics
PLAUSIBLE_DOMAIN="blog.creststudyconsult.com"
# Self-hosted Plausible URL (optional)

# ============================================
# Email (Resend - Phase 4)
# ============================================
# Get API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxx"
# Newsletter audience ID (optional - for managing subscribers)
RESEND_AUDIENCE_ID=""
# PLAUSIBLE_API_URL="https://plausible.io"

# ============================================
# Email / Newsletter (Phase 4)
# ============================================
# Resend API Key
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Newsletter from address
NEWSLETTER_FROM="Crest Study Consult <research@creststudyconsult.com>"

# ============================================
# Admin Auth (Phase 3)
# ============================================
# Initial admin email for seeding
ADMIN_EMAIL="admin@creststudyconsult.com"
# BCrypt rounds for password hashing
BCRYPT_ROUNDS="12"

# ============================================
# Super Admin API (External Access)
# ============================================
# Secure API key for super admin endpoints
# Generate with: openssl rand -hex 32
# CRITICAL: Keep this secret. Never commit to version control.
